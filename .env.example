# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_db_password_here
POSTGRES_DB=hub_osint
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Option to override database URL directly
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Option to override broker / backend URLs directly
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# App Settings
DEBUG=True
APP_NAME="OSINT & Private Intelligence Hub"
RSS_REFRESH_INTERVAL_SECONDS=3600

# Gemini AI Copilot Configuration (Optional)
# GEMINI_API_KEY=AIzaSy...your_gemini_api_key_here
